# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Installed dependencies (never commit; lockfiles stay tracked) ---
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# testing
coverage/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
frontend/coverage/

# next.js
.next/
out/

# production / build outputs
build/
dist/
*.egg-info/
.eggs/
*.egg

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env files (secrets only — keep .env.example / .env.local.example in git)
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python bytecode, venvs, caches (keep requirements.txt committed)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
backend/.venv/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# LaTeX build artifacts (docs/research); PDF optional to commit for submission
docs/**/*.aux
docs/**/*.log
docs/**/*.out
docs/**/*.toc
docs/**/*.synctex.gz
docs/**/*.fdb_latexmk
docs/**/*.fls

# IDE
.idea/
