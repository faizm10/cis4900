DATABASE_URL=postgresql://postgres:postgres@localhost:5434/cs_learning
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# Optional AI tutor — set LLM_PROVIDER then the matching credentials (one provider active).
# LLM_PROVIDER=openai
# LLM_TIMEOUT_SEC=60
#
# OpenAI or OpenAI-compatible (when LLM_PROVIDER=openai)
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
#
# Anthropic Claude (when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
#
# Google Gemini (when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
