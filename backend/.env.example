DATABASE_URL=postgresql://postgres:postgres@localhost:5434/cs_learning
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- AI tutor (optional): Claude / Anthropic (default) ---
# Create an API key: https://console.anthropic.com/ — paste it below (never commit this file filled in).
LLM_PROVIDER=anthropic
LLM_TIMEOUT_SEC=60
ANTHROPIC_API_KEY=
# Latest Sonnet (good balance for tutoring). Cheaper/faster: claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# --- Alternative: OpenAI-compatible (OpenAI, Ollama, etc.) ---
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Alternative: Google Gemini ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
